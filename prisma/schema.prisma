generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id        Int        @id @default(autoincrement())
  createdAt DateTime   @default(now())
  title     String     @db.VarChar(255)
  content   String?
  status    TaskStatus @default(TODO)
}

enum TaskStatus {
  DONE
  TODO
  ACTIVE
  PENDING
}